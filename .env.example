# Copiár este archivo a .env y completár con tus valores reales.
# NUNCA subas el archivo .env real a GitHub (ya está en .gitignore).

# ── Selección de proveedor de LLM ─────────────────────────────
# Opciones: anthropic | nvidia | groq | openrouter
LLM_PROVIDER=anthropic

# Opcional: override del modelo por defecto de cada proveedor.
# Si lo dejás vacío, se usa el default definido en app/llm_factory.py
# LLM_MODEL=claude-sonnet-4-6

# ── API keys (solo necesitás completar la del proveedor elegido) ──
ANTHROPIC_API_KEY=tu_api_key_aqui
NVIDIA_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Ruta del PDF dentro del contenedor (se monta desde ./data en tu máquina)
PDF_PATH=/data/documento.pdf
